# Path to the SQLite file. Use an absolute path on a mounted disk in prod.
DATABASE_PATH=./data/payments.db

# Seed the sample dataset on first boot when the database is empty.
SEED_ON_STARTUP=true
SEED_FILE=./data/sample_events.json

# API guard rails
MAX_BATCH_SIZE=5000
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500

# How long a transaction may sit unsettled before reconciliation calls it stale.
STALE_AFTER_HOURS=48

SQLITE_BUSY_TIMEOUT_MS=5000
