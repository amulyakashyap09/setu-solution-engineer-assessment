              "raw": "{\n  \"event_id\": \"demo-evt-bad\",\n  \"event_type\": \"payment_reversed\",\n  \"transaction_id\": \"demo-txn-001\",\n  \"merchant_id\": \"merchant_1\",\n  \"merchant_name\": \"QuickMart\",\n  \"amount\": 1499.5,\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-04-01T10:00:00+00:00\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
