              }
            ],
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "Amount must be greater than zero.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"demo-evt-neg\",\n  \"event_type\": \"payment_initiated\",\n  \"transaction_id\": \"demo-txn-001\",\n  \"merchant_id\": \"merchant_1\",\n  \"merchant_name\": \"QuickMart\",\n  \"amount\": -10,\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-04-01T10:00:00+00:00\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('422', () => pm.response.to.have.status(422));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Transactions",
      "item": [
        {
          "name": "List transactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions?limit=20&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transactions"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Page size, max 500"
                },
                {
                  "key": "offset",
                  "value": "0",
                  "description": "Rows to skip"
                }
              ]
            },
            "description": "Default page: 50 most recent first."
          }
        },
        {
          "name": "Filter by merchant",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions?merchant_id={{merchant_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transactions"
              ],
              "query": [
                {
                  "key": "merchant_id",
                  "value": "{{merchant_id}}",
                  "description": "Repeatable"
                }
              ]
            },
            "description": "Repeat merchant_id to filter on several merchants at once."
          }
        },
        {
          "name": "Filter by status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions?status=settled",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transactions"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "settled",
                  "description": "initiated|processed|failed|settled"
                }
              ]
            },
            "description": "Rolled-up status. Repeatable for multiple values."
          }
        },
        {
          "name": "Filter by settlement status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions?settlement_status=pending",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transactions"
              ],
              "query": [
                {
                  "key": "settlement_status",
                  "value": "pending",
                  "description": "pending|settled"
                }
              ]
            },
            "description": "The settlement axis, tracked independently of the payment axis."
          }
        },
        {
          "name": "Filter by date range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions?date_from=2026-01-01&date_to=2026-03-31&date_field=first_event_at",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transactions"
              ],
              "query": [
                {
                  "key": "date_from",
                  "value": "2026-01-01",
                  "description": "Inclusive"
                },
                {
                  "key": "date_to",
                  "value": "2026-03-31",
                  "description": "Inclusive"
                },
                {
                  "key": "date_field",
                  "value": "first_event_at",
                  "description": "Which timestamp to filter on"
                }
              ]
            },
            "description": "Bare dates are inclusive of the whole day. Full ISO-8601 also accepted."
          }
        },
        {
          "name": "Filter by amount range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions?min_amount=1000&max_amount=50000",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transactions"
              ],
              "query": [
                {
                  "key": "min_amount",
                  "value": "1000",
                  "description": ""
                },
                {
                  "key": "max_amount",
                  "value": "50000",
                  "description": ""
                }
              ]
            },
            "description": "Amounts are compared in exact integer minor units."
          }
        },
        {
          "name": "Sort by amount descending",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions?sort_by=amount&sort_order=desc&limit=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transactions"
              ],
              "query": [
                {
                  "key": "sort_by",
                  "value": "amount",
                  "description": "Whitelisted column"
                },
                {
                  "key": "sort_order",
                  "value": "desc",
                  "description": "asc|desc"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": ""
                }
              ]
            },
            "description": "Sort keys come from a whitelist; transaction_id is always appended as a tiebreaker so paging is stable."
          }
        },
        {
          "name": "Transactions that received duplicate events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions?has_duplicates=true",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transactions"
              ],
              "query": [
                {
                  "key": "has_duplicates",
                  "value": "true",
                  "description": ""
                }
              ]
            },
            "description": "Audit view of which transactions saw upstream redelivery."
          }
        },
        {
          "name": "Combined filters",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions?merchant_id={{merchant_id}}&status=settled&date_from=2026-02-01&sort_by=amount&sort_order=desc&limit=5",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transactions"
              ],
              "query": [
                {
                  "key": "merchant_id",
                  "value": "{{merchant_id}}",
                  "description": ""
                },
                {
                  "key": "status",
                  "value": "settled",
                  "description": ""
                },
                {
                  "key": "date_from",
                  "value": "2026-02-01",
                  "description": ""
                },
                {
                  "key": "sort_by",
                  "value": "amount",
                  "description": ""
                },
                {
                  "key": "sort_order",
                  "value": "desc",
                  "description": ""
                },
                {
                  "key": "limit",
                  "value": "5",
                  "description": ""
                }
              ]
            },
            "description": "All filters are ANDed together and resolved in SQL."
          }
        },
        {
          "name": "Get transaction detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions/{{transaction_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transactions",
                "{{transaction_id}}"
              ]
            },
            "description": "Transaction state, merchant, any discrepancies, and the full chronological event history."
          }
        },
        {
          "name": "Get transaction detail (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions/does-not-exist",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "transactions",
                "does-not-exist"
              ]
            },
            "description": "Standard not_found envelope."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Reconciliation",
      "item": [
        {
          "name": "Summary by merchant",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/reconciliation/summary?group_by=merchant",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "reconciliation",
                "summary"
              ],
              "query": [
                {
                  "key": "group_by",
                  "value": "merchant",
                  "description": "merchant|date|status|currency"
                }
              ]
            },
            "description": "Counts, exact amounts, settlement rate and discrepancy count per merchant."
          }
        },
        {
          "name": "Summary by date",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/reconciliation/summary?group_by=date",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "reconciliation",
                "summary"
              ],
              "query": [
                {
                  "key": "group_by",
                  "value": "date",
                  "description": ""
                }
              ]
            },
            "description": "Grouped on the date of each transaction's first event."
          }
