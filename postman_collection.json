{
  "info": {
    "name": "Payment Reconciliation Service",
    "description": "Backend service for ingesting payment lifecycle events and reconciling the payment leg against the settlement leg.\n\nSet the `base_url` variable to your deployment, or leave it as http://localhost:8000 for local use.\n\nRun the folders top to bottom: **1. Health** confirms the service is up, **2. Ingest** demonstrates idempotency, then the query folders read it back.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://setu-solution-engineer-assessment.onrender.com"
    },
    {
      "key": "transaction_id",
      "value": "demo-txn-001"
    },
    {
      "key": "merchant_id",
      "value": "merchant_1"
    }
  ],
  "item": [
    {
      "name": "1. Health & Meta",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Liveness plus row counts. Use this first to confirm the service is up and seeded."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('service is up', () => pm.response.to.have.status(200));",
                  "pm.test('has data', () => pm.expect(pm.response.json().events).to.be.above(0));"
                ]
              }
            }
          ]
        },
        {
          "name": "Service index",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": []
            },
            "description": "Lists every available endpoint."
          }
        },
        {
          "name": "List merchants",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/merchants",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "merchants"
              ]
            },
            "description": "All merchants with transaction volume and exact totals."
          }
        }
      ]
    },
    {
      "name": "2. Ingest Events (idempotency demo)",
      "item": [
        {
          "name": "Ingest a single event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "Returns 201 with created=1. Run it a second time to see 200 with duplicates=1.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"demo-evt-001\",\n  \"event_type\": \"payment_initiated\",\n  \"transaction_id\": \"demo-txn-001\",\n  \"merchant_id\": \"merchant_1\",\n  \"merchant_name\": \"QuickMart\",\n  \"amount\": 1499.5,\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-04-01T10:00:00+00:00\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 or 201', () => pm.expect([200,201]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "Ingest the SAME event again (duplicate)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "Idempotency: same event_id. Returns 200, created=0, duplicates=1. No second row, no state change.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": \"demo-evt-001\",\n  \"event_type\": \"payment_initiated\",\n  \"transaction_id\": \"demo-txn-001\",\n  \"merchant_id\": \"merchant_1\",\n  \"merchant_name\": \"QuickMart\",\n  \"amount\": 1499.5,\n  \"currency\": \"INR\",\n  \"timestamp\": \"2026-04-01T10:00:00+00:00\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 not 201', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('nothing created', () => pm.expect(b.created).to.eql(0));",
                  "pm.test('flagged duplicate', () => pm.expect(b.duplicates).to.eql(1));"
                ]
              }
            }
          ]
        },
        {
          "name": "Ingest a batch (array)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "A bare array of events, applied atomically in one transaction.",
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"event_id\": \"demo-evt-002\",\n    \"event_type\": \"payment_processed\",\n    \"transaction_id\": \"demo-txn-001\",\n    \"merchant_id\": \"merchant_1\",\n    \"merchant_name\": \"QuickMart\",\n    \"amount\": 1499.5,\n    \"currency\": \"INR\",\n    \"timestamp\": \"2026-04-01T10:05:00+00:00\"\n  },\n  {\n    \"event_id\": \"demo-evt-003\",\n    \"event_type\": \"settled\",\n    \"transaction_id\": \"demo-txn-001\",\n    \"merchant_id\": \"merchant_1\",\n    \"merchant_name\": \"QuickMart\",\n    \"amount\": 1499.5,\n    \"currency\": \"INR\",\n    \"timestamp\": \"2026-04-01T14:00:00+00:00\"\n  }\n]",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 or 201', () => pm.expect([200,201]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "Ingest a batch (wrapped object)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "The same batch under an `events` key. Both shapes are accepted.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"events\": [\n    {\n      \"event_id\": \"demo-evt-004\",\n      \"event_type\": \"payment_initiated\",\n      \"transaction_id\": \"demo-txn-002\",\n      \"merchant_id\": \"merchant_1\",\n      \"merchant_name\": \"QuickMart\",\n      \"amount\": 880.0,\n      \"currency\": \"INR\",\n      \"timestamp\": \"2026-04-02T09:00:00+00:00\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 or 201', () => pm.expect([200,201]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "Ingest out-of-order events",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "Settled arrives before initiated. The MIN() fold means the projection converges on the same state regardless of arrival order.",
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"event_id\": \"demo-evt-005\",\n    \"event_type\": \"settled\",\n    \"transaction_id\": \"demo-txn-003\",\n    \"merchant_id\": \"merchant_1\",\n    \"merchant_name\": \"QuickMart\",\n    \"amount\": 1499.5,\n    \"currency\": \"INR\",\n    \"timestamp\": \"2026-04-03T18:00:00+00:00\"\n  },\n  {\n    \"event_id\": \"demo-evt-006\",\n    \"event_type\": \"payment_initiated\",\n    \"transaction_id\": \"demo-txn-003\",\n    \"merchant_id\": \"merchant_1\",\n    \"merchant_name\": \"QuickMart\",\n    \"amount\": 1499.5,\n    \"currency\": \"INR\",\n    \"timestamp\": \"2026-04-03T09:00:00+00:00\"\n  },\n  {\n    \"event_id\": \"demo-evt-007\",\n    \"event_type\": \"payment_processed\",\n    \"transaction_id\": \"demo-txn-003\",\n    \"merchant_id\": \"merchant_1\",\n    \"merchant_name\": \"QuickMart\",\n    \"amount\": 1499.5,\n    \"currency\": \"INR\",\n    \"timestamp\": \"2026-04-03T09:05:00+00:00\"\n  }\n]",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 or 201', () => pm.expect([200,201]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create a discrepancy (settled after failure)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "Settlement recorded against a payment the rail reported as failed. Shows up as SETTLED_AFTER_FAILURE, severity high.",
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"event_id\": \"demo-evt-008\",\n    \"event_type\": \"payment_initiated\",\n    \"transaction_id\": \"demo-txn-bad\",\n    \"merchant_id\": \"merchant_1\",\n    \"merchant_name\": \"QuickMart\",\n    \"amount\": 1499.5,\n    \"currency\": \"INR\",\n    \"timestamp\": \"2026-04-04T09:00:00+00:00\"\n  },\n  {\n    \"event_id\": \"demo-evt-009\",\n    \"event_type\": \"payment_failed\",\n    \"transaction_id\": \"demo-txn-bad\",\n    \"merchant_id\": \"merchant_1\",\n    \"merchant_name\": \"QuickMart\",\n    \"amount\": 1499.5,\n    \"currency\": \"INR\",\n    \"timestamp\": \"2026-04-04T09:10:00+00:00\"\n  },\n  {\n    \"event_id\": \"demo-evt-010\",\n    \"event_type\": \"settled\",\n    \"transaction_id\": \"demo-txn-bad\",\n    \"merchant_id\": \"merchant_1\",\n    \"merchant_name\": \"QuickMart\",\n    \"amount\": 1499.5,\n    \"currency\": \"INR\",\n    \"timestamp\": \"2026-04-04T13:00:00+00:00\"\n  }\n]",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 or 201', () => pm.expect([200,201]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        },
        {
          "name": "Validation error: bad event type",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "events"
              ]
            },
            "description": "Returns 422 with a per-field error list in the standard envelope.",
            "body": {
